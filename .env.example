# Django settings
SECRET_KEY=replace-with-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Email configuration (optional example)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=webmaster@localhost

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgres://ecard_user:ecard_pass@localhost:5432/ecard_db

# Security toggles
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False

# ---- bKash Recurring Payment ----
# Fill these after bKash provisions sandbox credentials at the S-2 milestone.
BKASH_MODE=sandbox
BKASH_BASE_URL=https://gateway.sbrecurring.pay.bka.sh
BKASH_APP_KEY=
BKASH_MERCHANT_SHORT_CODE=
BKASH_SERVICE_ID=100001
BKASH_WEBHOOK_KEY=
BKASH_DISPLAY_NAME=MY-Card by Dupno
BKASH_REDIRECT_URL=https://mycard.dupno.com/pay/bkash/return/
BKASH_WEBHOOK_URL=https://mycard.dupno.com/pay/bkash/webhook/

# Card lifecycle overrides (defaults are set in settings.py)
# CARD_TRIAL_MONTHS=12
# CARD_YEARLY_PRICE_FREE=120
# CARD_YEARLY_PRICE_PRO=500
# CARD_GRACE_PERIOD_DAYS=7
